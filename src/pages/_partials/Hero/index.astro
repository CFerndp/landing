---
import { profile } from "../../../data/profile";
import NeonButton from "../../../components/atoms/NeonButton/index.astro";
---

<section id="hero">
    <div class="hero-ring"></div>
    <div class="hero-ring"></div>
    <div class="hero-ring"></div>

    <h1 class="hero-name font-orbitron">{profile.name}</h1>

    <div class="typewriter-wrapper">
        <p class="hero-subtitle typewriter">{profile.subtitle}</p>
    </div>

    <p class="hero-location font-mono">{profile.location}</p>

    <p class="hero-tagline">{profile.tagline}</p>

    <div class="hero-stats">
        {
            profile.stats.map((stat) => (
                <div class="hero-stat">
                    <div class="hero-stat-number font-orbitron">
                        {stat.number}
                    </div>
                    <div class="hero-stat-label">{stat.label}</div>
                </div>
            ))
        }
    </div>

    <div class="hero-cta">
        <NeonButton href="/#contact" color="blue">Get In Touch</NeonButton>
        <NeonButton
            href="https://www.linkedin.com/in/cferndp/"
            color="pink"
            target="_blank"
            rel="noopener noreferrer">View LinkedIn</NeonButton
        >
        <NeonButton
            href="/cv_cristian_fernandez.pdf"
            color="green"
            download="cv_cristian_fernandez.pdf">&#8659; Download CV</NeonButton
        >
    </div>
</section>

<script>
    const rings = document.querySelectorAll<HTMLElement>("#hero .hero-ring");

    window.addEventListener(
        "scroll",
        () => {
            const scrollY = window.scrollY;
            rings.forEach((ring, i) => {
                const direction = i % 2 === 0 ? 1 : -1;
                const speed = 0.06 + i * 0.03;
                const translateY = scrollY * speed * direction;
                const scale = 1 + scrollY * 0.00008;
                ring.style.transform = `translate(-50%, calc(-50% + ${translateY}px)) scale(${scale})`;
            });
        },
        { passive: true },
    );
</script>

<style>
    #hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding-top: 5rem;
        position: relative;
    }

    .hero-ring {
        position: absolute;
        border-radius: 50%;
        border: 1px solid;
        opacity: 0.12;
        animation: ringPulse 6s ease-in-out infinite;
        pointer-events: none;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    .hero-ring:nth-child(1) {
        width: 420px;
        height: 420px;
        border-color: #00e5ff;
        animation-delay: 0s;
    }
    .hero-ring:nth-child(2) {
        width: 560px;
        height: 560px;
        border-color: #ff2d95;
        animation-delay: 1s;
    }
    .hero-ring:nth-child(3) {
        width: 700px;
        height: 700px;
        border-color: #bf5fff;
        animation-delay: 2s;
    }

    .hero-name {
        font-size: clamp(2rem, 6vw, 4rem);
        font-weight: 800;
        letter-spacing: 6px;
        text-transform: uppercase;
        background: linear-gradient(135deg, #00e5ff, #bf5fff, #ff2d95);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: gradientShift 5s ease infinite;
        background-size: 200% 200%;
        position: relative;
        z-index: 1;
    }

    .hero-subtitle {
        font-size: clamp(0.9rem, 2.5vw, 1.2rem);
        color: #39ff14;
        text-shadow: 0 0 10px rgba(57, 255, 20, 0.5);
        margin-top: 0.8rem;
        letter-spacing: 3px;
        position: relative;
        z-index: 1;
    }

    .hero-location {
        font-size: 0.85rem;
        color: #bf5fff;
        margin-top: 0.6rem;
        letter-spacing: 2px;
        text-shadow: 0 0 8px rgba(191, 95, 255, 0.4);
        position: relative;
        z-index: 1;
    }

    .hero-tagline {
        font-size: 1rem;
        color: #888;
        margin-top: 1rem;
        max-width: 600px;
        letter-spacing: 1px;
        position: relative;
        z-index: 1;
    }

    .hero-stats {
        display: flex;
        gap: 2.5rem;
        margin-top: 2.5rem;
        flex-wrap: wrap;
        justify-content: center;
        position: relative;
        z-index: 1;
    }

    .hero-stat {
        text-align: center;
    }

    .hero-stat-number {
        font-size: 1.8rem;
        font-weight: 700;
        color: #00e5ff;
        text-shadow: 0 0 15px rgba(0, 229, 255, 0.5);
    }

    .hero-stat-label {
        font-size: 0.75rem;
        color: #777;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .hero-cta {
        margin-top: 2.5rem;
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        justify-content: center;
        position: relative;
        z-index: 1;
    }

    @media (max-width: 768px) {
        .hero-ring {
            display: none;
        }
    }

    @media (min-width: 375px) and (max-width: 600px) {
        .hero-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem 2rem;
        }
        .hero-stat:last-child {
            grid-column: 1 / -1;
            justify-self: center;
        }
        .hero-stat-number {
            font-size: 2rem;
        }
        .hero-stat-label {
            font-size: 0.7rem;
        }
    }

    @media (max-width: 374px) {
        .hero-stats {
            flex-direction: column;
            align-items: center;
            gap: 1rem;
        }
    }
</style>
