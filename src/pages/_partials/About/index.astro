---
import { profile } from "../../../data/profile";
import SectionTitle from "../../../components/atoms/SectionTitle/index.astro";
import NeonBadge from "../../../components/atoms/NeonBadge/index.astro";
---

<section id="about">
    <SectionTitle color="blue">About Me</SectionTitle>

    <div class="about-content reveal">
        <div class="about-text">
            {
                profile.bio.map((paragraph) => (
                    <p class="bio-paragraph">{paragraph}</p>
                ))
            }
        </div>

        <div class="about-details neon-card">
            {
                profile.details.map((detail) => (
                    <div class="about-detail-item">
                        <span class="about-detail-label font-mono">
                            {detail.label}
                        </span>
                        <span class="about-detail-value">{detail.value}</span>
                    </div>
                ))
            }

            <div class="about-detail-item interests-section">
                <span class="about-detail-label font-mono">INTERESTS</span>
                <div class="interests-list">
                    {
                        profile.interests.map((interest) => (
                            <NeonBadge color="purple" shape="pill">
                                {interest}
                            </NeonBadge>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .about-content {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: start;
    }

    .about-text {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .bio-paragraph {
        color: #bbb;
        line-height: 1.8;
        font-size: 1rem;
    }

    /* Extends .neon-card utility */
    .about-details {
        border: 1px solid rgba(0, 229, 255, 0.1);
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .about-detail-item {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 1rem;
        padding: 0.75rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .about-detail-item:last-child {
        border-bottom: none;
        flex-direction: column;
        gap: 0.8rem;
    }

    .about-detail-label {
        font-size: 0.8rem;
        color: #00e5ff;
        text-transform: uppercase;
        letter-spacing: 2px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .about-detail-value {
        color: #ccc;
        font-size: 0.95rem;
        text-align: right;
    }

    .interests-section {
        padding-top: 0.75rem;
    }

    .interests-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    @media (max-width: 768px) {
        .about-content {
            grid-template-columns: 1fr;
            gap: 2rem;
        }
    }

    @media (max-width: 600px) {
        .about-details {
            padding: 1.5rem;
        }
        .about-detail-item {
            flex-direction: column;
            gap: 0.3rem;
        }
        .about-detail-value {
            text-align: left;
        }
    }
</style>
