---
import { contact } from "../../../data/contact";
import SectionTitle from "../../../components/atoms/SectionTitle/index.astro";
import ContactCard from "../../../components/molecules/ContactCard/index.astro";
---

<section id="contact">
    <SectionTitle color="blue">Let's Connect</SectionTitle>

    <p class="contact-subtitle reveal">
        Open to new opportunities, collaborations, and interesting
        conversations. Don't hesitate to reach out!
    </p>

    <div class="contact-grid">
        {
            contact.map((item, index) => (
                <div class={`reveal stagger-${(index % 3) + 1}`}>
                    <ContactCard
                        label={item.label}
                        value={item.value}
                        displayValue={item.displayValue}
                        iconColor={item.iconColor}
                        icon={item.icon}
                        isExternal={item.isExternal}
                    />
                </div>
            ))
        }
    </div>
</section>

<style>
    .contact-subtitle {
        text-align: center;
        color: #888;
        margin-bottom: 3rem;
        font-size: 1rem;
        line-height: 1.8;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1.5rem;
        max-width: 800px;
        margin: 0 auto;
    }

    @media (max-width: 400px) {
        .contact-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
