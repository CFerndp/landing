---
type ContactColor = 'blue' | 'green' | 'pink';

interface Props {
  label: string;
  value: string;
  displayValue: string;
  iconColor: ContactColor;
  icon: string;
  isExternal: boolean;
}

const { label, value, displayValue, iconColor, icon, isExternal } = Astro.props;
---

<a
  href={value}
  class={`contact-card contact-card--${iconColor}`}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
>
  <div class={`contact-icon contact-icon--${iconColor}`}>{icon}</div>
  <div class="contact-info">
    <div class="contact-label font-mono">{label}</div>
    <div class="contact-value">{displayValue}</div>
  </div>
</a>

<style>
  .contact-card {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 1.2rem;
    background: var(--card-bg);
    border-radius: 8px;
    padding: 1.5rem;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.06);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .contact-card::before {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 2px;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.35s ease;
  }

  .contact-card--blue::before  { background: #00e5ff; box-shadow: 0 0 8px #00e5ff; }
  .contact-card--green::before { background: #39ff14; box-shadow: 0 0 8px #39ff14; }
  .contact-card--pink::before  { background: #ff2d95; box-shadow: 0 0 8px #ff2d95; }

  .contact-card:hover::before  { transform: scaleX(1); }
  .contact-card:hover          { transform: translateY(-4px); }

  .contact-card--blue:hover  { border-color: rgba(0, 229, 255, 0.3);  box-shadow: 0 8px 30px rgba(0, 229, 255, 0.15); }
  .contact-card--green:hover { border-color: rgba(57, 255, 20, 0.3);  box-shadow: 0 8px 30px rgba(57, 255, 20, 0.15); }
  .contact-card--pink:hover  { border-color: rgba(255, 45, 149, 0.3); box-shadow: 0 8px 30px rgba(255, 45, 149, 0.15); }

  .contact-icon {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-family: 'Orbitron', sans-serif;
    font-weight: 700;
    transition: box-shadow 0.3s ease;
  }

  .contact-icon--blue  { background: rgba(0, 229, 255, 0.1);  color: #00e5ff; border: 1px solid rgba(0, 229, 255, 0.2); }
  .contact-icon--green { background: rgba(57, 255, 20, 0.1);  color: #39ff14; border: 1px solid rgba(57, 255, 20, 0.2); }
  .contact-icon--pink  { background: rgba(255, 45, 149, 0.1); color: #ff2d95; border: 1px solid rgba(255, 45, 149, 0.2); }

  .contact-card:hover .contact-icon--blue  { box-shadow: 0 0 16px rgba(0, 229, 255, 0.4); }
  .contact-card:hover .contact-icon--green { box-shadow: 0 0 16px rgba(57, 255, 20, 0.4); }
  .contact-card:hover .contact-icon--pink  { box-shadow: 0 0 16px rgba(255, 45, 149, 0.4); }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-width: 0;
  }

  .contact-label {
    font-size: 0.7rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .contact-value {
    color: #ddd;
    font-size: 0.95rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.3s ease;
  }

  .contact-card--blue:hover  .contact-value { color: #00e5ff; }
  .contact-card--green:hover .contact-value { color: #39ff14; }
  .contact-card--pink:hover  .contact-value { color: #ff2d95; }
</style>
