---
import NeonBadge from "../../atoms/NeonBadge/index.astro";

interface SkillTag {
    label: string;
    color: "blue" | "green" | "pink" | "purple";
}

interface Props {
    title: string;
    tags: SkillTag[];
}

const { title, tags } = Astro.props;
---

<div class="skill-cat neon-card">
    <div class="skill-cat__title font-orbitron">{title}</div>
    <div class="skill-cat__tags">
        {
            tags.map((tag) => (
                <NeonBadge color={tag.color} shape="square">
                    {tag.label}
                </NeonBadge>
            ))
        }
    </div>
</div>

<style>
    .skill-cat {
        height: 100%;
        display: flex;
        flex-direction: column;
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 1.8rem;
        transition:
            border-color 0.3s ease,
            box-shadow 0.3s ease,
            transform 0.3s ease;
    }

    .skill-cat:hover {
        border-color: rgba(57, 255, 20, 0.35);
        box-shadow:
            0 0 20px rgba(57, 255, 20, 0.12),
            inset 0 0 20px rgba(57, 255, 20, 0.04);
        transform: translateY(-2px);
    }

    .skill-cat__title {
        font-size: 0.85rem;
        color: #39ff14;
        text-transform: uppercase;
        letter-spacing: 3px;
        margin-bottom: 1.2rem;
        text-shadow: 0 0 10px rgba(57, 255, 20, 0.4);
    }

    .skill-cat__tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    @media (max-width: 400px) {
        .skill-cat {
            padding: 1.4rem;
        }
    }
</style>
