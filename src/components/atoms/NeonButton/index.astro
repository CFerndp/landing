---
interface Props {
  href?: string;
  color?: 'blue' | 'pink';
  target?: string;
  rel?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
}

const {
  href,
  color = 'blue',
  target,
  rel,
  type = 'button',
  class: className = '',
} = Astro.props;
---

{href ? (
  <a
    href={href}
    target={target}
    rel={rel}
    class={`btn-neon btn--${color} ${className}`}
  >
    <slot />
  </a>
) : (
  <button type={type} class={`btn-neon btn--${color} ${className}`}>
    <slot />
  </button>
)}

<style>
  .btn-neon {
    display: inline-block;
    padding: 0.8rem 2rem;
    font-family: 'Orbitron', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.35s ease;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    background: transparent;
  }

  .btn-neon::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent, rgba(255, 255, 255, 0.1), transparent);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }

  .btn-neon:hover::before { transform: translateX(100%); }

  .btn--blue {
    color: #00e5ff;
    border: 1px solid #00e5ff;
  }
  .btn--blue:hover {
    background: rgba(0, 229, 255, 0.1);
    box-shadow: 0 0 25px rgba(0, 229, 255, 0.4), inset 0 0 25px rgba(0, 229, 255, 0.1);
    text-shadow: 0 0 8px #00e5ff;
  }

  .btn--pink {
    color: #ff2d95;
    border: 1px solid #ff2d95;
  }
  .btn--pink:hover {
    background: rgba(255, 45, 149, 0.1);
    box-shadow: 0 0 25px rgba(255, 45, 149, 0.4), inset 0 0 25px rgba(255, 45, 149, 0.1);
    text-shadow: 0 0 8px #ff2d95;
  }
</style>
