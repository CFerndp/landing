---
interface Props {
    date: string;
    role: string;
    company: string;
    items: string[];
}

const { date, role, company, items } = Astro.props;
---

<div class="timeline-item">
    <div class="tl-date font-mono">{date}</div>
    <div class="tl-role font-orbitron">{role}</div>
    <div class="tl-company">{company}</div>
    <ul class="neon-list tl-desc">
        {items.map((bullet) => <li>{bullet}</li>)}
    </ul>
</div>

<style>
    .timeline-item {
        position: relative;
        background: var(--card-bg);
        border: 1px solid rgba(0, 229, 255, 0.08);
        border-radius: 8px;
        padding: 1.8rem;
        margin-bottom: 1.8rem;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        transition:
            transform 0.3s ease,
            border-color 0.3s ease,
            box-shadow 0.3s ease;
    }

    .timeline-item:hover {
        transform: translateX(6px);
        border-color: rgba(0, 229, 255, 0.35);
        box-shadow:
            0 0 20px rgba(0, 229, 255, 0.12),
            -4px 0 20px rgba(0, 229, 255, 0.08);
    }

    /* Timeline dot */
    .timeline-item::before {
        content: "";
        position: absolute;
        left: -3rem;
        top: 1.8rem;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: #0a0a0f;
        border: 2px solid #00e5ff;
        box-shadow:
            0 0 10px rgba(0, 229, 255, 0.7),
            0 0 20px rgba(0, 229, 255, 0.3);
        margin-left: -5px;
        transition:
            border-color 0.3s ease,
            box-shadow 0.3s ease;
    }

    .timeline-item:hover::before {
        border-color: #bf5fff;
        box-shadow:
            0 0 10px rgba(191, 95, 255, 0.7),
            0 0 20px rgba(191, 95, 255, 0.3);
    }

    .tl-date {
        font-size: 0.8rem;
        color: #39ff14;
        letter-spacing: 2px;
        text-shadow: 0 0 8px rgba(57, 255, 20, 0.4);
        margin-bottom: 0.5rem;
    }

    .tl-role {
        font-size: clamp(0.95rem, 2vw, 1.1rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 0.3rem;
    }

    .tl-company {
        font-size: 0.95rem;
        color: #ff2d95;
        text-shadow: 0 0 8px rgba(255, 45, 149, 0.3);
        margin-bottom: 1rem;
        letter-spacing: 1px;
    }

    @media (max-width: 768px) {
        .timeline-item::before {
            left: -2rem;
        }
    }

    @media (max-width: 600px) {
        .timeline-item {
            padding: 1.4rem;
        }
        .timeline-item::before {
            left: -1.5rem;
            width: 10px;
            height: 10px;
            margin-left: -4px;
        }
    }

    @media (max-width: 374px) {
        .timeline-item::before {
            left: -1.2rem;
            width: 8px;
            height: 8px;
            margin-left: -3px;
        }
    }
</style>
