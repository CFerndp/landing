---
import BaseLayout from "../../layouts/BaseLayout/index.astro";
import Navbar from "../../components/Navbar/index.astro";
import Footer from "../../components/Footer/index.astro";
import PostCard from "./_partials/PostCard/index.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const posts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
    title="Blog — Cristian Fernandez"
    description="Technical articles on React, TypeScript, architecture and software development."
>
    <Navbar />

    <main>
        <section class="blog-section">
            <h1 class="section-title title-blue">
                // Blog<span class="line"></span>
            </h1>

            {
                posts.length === 0 ? (
                    <div class="empty-state">
                        <p class="empty-message">
                            No posts yet. Check back soon!
                        </p>
                    </div>
                ) : (
                    <div class="posts-grid">
                        {posts.map((post) => (
                            <PostCard
                                title={post.data.title}
                                description={post.data.description}
                                pubDate={post.data.pubDate}
                                tags={post.data.tags}
                                slug={post.id}
                                minutesRead={post.data.minutesRead}
                                draft={post.data.draft}
                            />
                        ))}
                    </div>
                )
            }
        </section>
    </main>

    <Footer />
</BaseLayout>

<style>
    .blog-section {
        position: relative;
        z-index: 1;
        max-width: 1100px;
        margin: 0 auto;
        padding: 6rem 2rem 4rem;
    }

    .empty-state {
        text-align: center;
        padding: 5rem 0;
    }

    .empty-message {
        font-family: "Share Tech Mono", monospace;
        color: #39ff14;
        font-size: 1rem;
        letter-spacing: 2px;
        text-shadow: 0 0 10px rgba(57, 255, 20, 0.4);
    }

    .posts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 2rem;
    }

    @media (max-width: 768px) {
        .blog-section {
            padding: 5rem 1.2rem 3rem;
        }

        .posts-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 400px) {
        .blog-section {
            padding: 4rem 1rem 2.5rem;
        }
    }
</style>
