---
import BaseLayout from "../../layouts/BaseLayout/index.astro";
import Navbar from "../../components/Navbar/index.astro";
import Footer from "../../components/Footer/index.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("blog", ({ data }) => !data.draft);
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<BaseLayout
    title={`${post.data.title} — Cristian Fernandez`}
    description={post.data.description}
>
    <Navbar />

    <main>
        <article class="post-wrapper">
            <a href="/blog" class="back-link">← Back to Blog</a>

            <header class="post-header">
                <time
                    class="post-date"
                    datetime={post.data.pubDate.toISOString()}
                >
                    {formattedDate}
                </time>

                {
                    post.data.minutesRead && (
                        <span class="minutes-read">
                            &nbsp;·&nbsp;{post.data.minutesRead} min read
                        </span>
                    )
                }

                <h1 class="post-title">{post.data.title}</h1>

                {
                    post.data.tags.length > 0 && (
                        <div class="post-tags">
                            {post.data.tags.map((tag) => (
                                <span class="post-tag">{tag}</span>
                            ))}
                        </div>
                    )
                }

                <hr class="post-divider" />
            </header>

            <div class="prose">
                <Content />
            </div>

            <div class="post-footer">
                <a href="/blog" class="back-link back-link--bottom"
                    >← Back to Blog</a
                >
            </div>
        </article>
    </main>

    <Footer />
</BaseLayout>

<style>
    main {
        position: relative;
        z-index: 1;
    }

    /* ── Wrapper ─────────────────────────────────────────────────────────────── */
    .post-wrapper {
        max-width: 800px;
        margin: 0 auto;
        padding: 6rem 2rem 4rem;
        position: relative;
        z-index: 1;
    }

    /* ── Back link ───────────────────────────────────────────────────────────── */
    .back-link {
        display: inline-block;
        font-family: "Share Tech Mono", monospace;
        font-size: 0.8rem;
        letter-spacing: 1.5px;
        color: #00e5ff;
        text-decoration: none;
        margin-bottom: 2.5rem;
        text-transform: uppercase;
        transition:
            text-shadow 0.3s ease,
            color 0.3s ease;
    }

    .back-link:hover {
        text-shadow:
            0 0 10px rgba(0, 229, 255, 0.8),
            0 0 20px rgba(0, 229, 255, 0.4);
        color: #fff;
    }

    /* ── Post header ─────────────────────────────────────────────────────────── */
    .post-header {
        margin-bottom: 0;
    }

    .post-date {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.8rem;
        color: #39ff14;
        letter-spacing: 1.5px;
        text-transform: uppercase;
    }

    .minutes-read {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.8rem;
        color: #555;
        letter-spacing: 1px;
    }

    /* ── Post title ──────────────────────────────────────────────────────────── */
    .post-title {
        font-family: "Orbitron", sans-serif;
        font-size: clamp(1.5rem, 4vw, 2.4rem);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 3px;
        line-height: 1.2;
        margin-top: 1rem;
        margin-bottom: 1.5rem;
        background: linear-gradient(
            135deg,
            #00e5ff 0%,
            #bf5fff 60%,
            #ff2d95 100%
        );
        background-size: 200% 200%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: gradientShift 6s ease infinite;
    }

    @keyframes gradientShift {
        0% {
            background-position: 0% 50%;
        }
        50% {
            background-position: 100% 50%;
        }
        100% {
            background-position: 0% 50%;
        }
    }

    /* ── Tags ────────────────────────────────────────────────────────────────── */
    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
    }

    .post-tag {
        font-family: "Share Tech Mono", monospace;
        font-size: 0.75rem;
        padding: 0.25rem 0.7rem;
        border-radius: 4px;
        background: rgba(0, 229, 255, 0.06);
        border: 1px solid rgba(0, 229, 255, 0.15);
        color: #00e5ff;
        letter-spacing: 0.5px;
        transition:
            background 0.3s ease,
            border-color 0.3s ease;
    }

    .post-tag:hover {
        background: rgba(0, 229, 255, 0.12);
        border-color: rgba(0, 229, 255, 0.3);
    }

    /* ── Divider ─────────────────────────────────────────────────────────────── */
    .post-divider {
        border: none;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
        margin: 2rem 0;
    }

    /* ── Post footer ─────────────────────────────────────────────────────────── */
    .post-footer {
        margin-top: 4rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.08);
    }

    .back-link--bottom {
        margin-bottom: 0;
    }

    /* ── Responsive ──────────────────────────────────────────────────────────── */
    @media (max-width: 768px) {
        .post-wrapper {
            padding: 5rem 1.2rem 3rem;
        }

        .post-title {
            letter-spacing: 1.5px;
        }
    }

    @media (max-width: 400px) {
        .post-wrapper {
            padding: 4rem 1rem 2.5rem;
        }
    }
</style>
