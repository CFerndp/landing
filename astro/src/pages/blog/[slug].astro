---
import "./post.css";
import BaseLayout from "../../layouts/BaseLayout/index.astro";
import Navbar from "../../components/Navbar/index.astro";
import Footer from "../../components/Footer/index.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
    const posts = await getCollection("blog", ({ data }) => !data.draft);
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<BaseLayout
    title={`${post.data.title} — Cristian Fernandez`}
    description={post.data.description}
>
    <Navbar />

    <main>
        <article class="post-wrapper">
            <a href="/blog" class="back-link">← Back to Blog</a>

            <header class="post-header">
                <time
                    class="post-date"
                    datetime={post.data.pubDate.toISOString()}
                >
                    {formattedDate}
                </time>

                {
                    post.data.minutesRead && (
                        <span class="minutes-read">
                            &nbsp;·&nbsp;{post.data.minutesRead} min read
                        </span>
                    )
                }

                <h1 class="post-title">{post.data.title}</h1>

                {
                    post.data.tags.length > 0 && (
                        <div class="post-tags">
                            {post.data.tags.map((tag) => (
                                <span class="post-tag">{tag}</span>
                            ))}
                        </div>
                    )
                }

                <hr class="post-divider" />
            </header>

            <div class="prose">
                <Content />
            </div>

            <div class="post-footer">
                <a href="/blog" class="back-link back-link--bottom"
                    >← Back to Blog</a
                >
            </div>
        </article>
    </main>

    <Footer />
</BaseLayout>
