---
import { profile } from "../../../data/profile";
import "./styles.css";
---

<section id="hero">
    <div class="hero-ring"></div>
    <div class="hero-ring"></div>
    <div class="hero-ring"></div>

    <h1 class="hero-name font-orbitron">{profile.name}</h1>

    <div class="typewriter-wrapper">
        <p class="hero-subtitle typewriter">{profile.subtitle}</p>
    </div>

    <p class="hero-location font-mono">{profile.location}</p>

    <p class="hero-tagline">{profile.tagline}</p>

    <div class="hero-stats">
        {
            profile.stats.map((stat) => (
                <div class="hero-stat">
                    <div class="hero-stat-number font-orbitron">
                        {stat.number}
                    </div>
                    <div class="hero-stat-label">{stat.label}</div>
                </div>
            ))
        }
    </div>

    <div class="hero-cta">
        <a href="/#contact" class="btn-neon btn-blue">Get In Touch</a>
        <a
            href="https://www.linkedin.com/in/cferndp/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-neon btn-pink">View LinkedIn</a
        >
    </div>
</section>

<script>
    // Parallax: on scroll, shift .hero-ring elements with translateY + scale
    const rings = document.querySelectorAll<HTMLElement>("#hero .hero-ring");

    window.addEventListener(
        "scroll",
        () => {
            const scrollY = window.scrollY;
            rings.forEach((ring, i) => {
                const direction = i % 2 === 0 ? 1 : -1;
                const speed = 0.06 + i * 0.03;
                const translateY = scrollY * speed * direction;
                const scale = 1 + scrollY * 0.00008;
                ring.style.transform = `translate(-50%, calc(-50% + ${translateY}px)) scale(${scale})`;
            });
        },
        { passive: true },
    );
</script>
