---
import { profile } from "../../../data/profile";
import "./styles.css";
---

<section id="about">
    <h2 class="section-title title-blue reveal">
        About Me<span class="line"></span>
    </h2>

    <div class="about-content reveal">
        <!-- Left: Bio -->
        <div class="about-text">
            {
                profile.bio.map((paragraph) => (
                    <p class="bio-paragraph">{paragraph}</p>
                ))
            }
        </div>

        <!-- Right: Details card -->
        <div class="about-details">
            {
                profile.details.map((detail) => (
                    <div class="about-detail-item">
                        <span class="about-detail-label font-mono">
                            {detail.label}
                        </span>
                        <span class="about-detail-value">{detail.value}</span>
                    </div>
                ))
            }

            <div class="about-detail-item interests-section">
                <span class="about-detail-label font-mono">INTERESTS</span>
                <div class="interests-list">
                    {
                        profile.interests.map((interest) => (
                            <span class="interest-tag">{interest}</span>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>
