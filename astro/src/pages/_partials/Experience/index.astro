---
import { experience } from "../../../data/experience";
import "./styles.css";
---

<section id="experience">
    <h2 class="section-title title-pink reveal">
        Work Experience<span class="line"></span>
    </h2>

    <div class="timeline">
        {
            experience.map((item, index) => (
                <div class={`timeline-item reveal stagger-${(index % 5) + 1}`}>
                    <div class="timeline-date font-mono">{item.date}</div>
                    <div class="timeline-role font-orbitron">{item.role}</div>
                    <div class="timeline-company">{item.company}</div>
                    <ul class="timeline-desc">
                        {item.items.map((bullet) => (
                            <li>{bullet}</li>
                        ))}
                    </ul>
                </div>
            ))
        }
    </div>
</section>
