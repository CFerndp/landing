---
import { skills } from '../../../data/skills';
---

<section id="skills">
  <h2 class="section-title title-green reveal">Tech Stack<span class="line"></span></h2>

  <div class="skills-grid">
    {skills.map((category, i) => (
      <div class={`skill-category reveal stagger-${(i % 5) + 1}`}>
        <div class="skill-cat-title font-orbitron">{category.title}</div>
        <div class="skill-tags">
          {category.tags.map(tag => (
            <span class={`skill-tag skill-tag--${tag.color} font-mono`}>{tag.label}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .skill-category {
    background: var(--card-bg);
    border-radius: 8px;
    padding: 1.8rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .skill-category:hover {
    border-color: rgba(57, 255, 20, 0.35);
    box-shadow: 0 0 20px rgba(57, 255, 20, 0.12), inset 0 0 20px rgba(57, 255, 20, 0.04);
    transform: translateY(-2px);
  }

  .skill-cat-title {
    font-size: 0.85rem;
    color: #39ff14;
    text-transform: uppercase;
    letter-spacing: 3px;
    margin-bottom: 1.2rem;
    text-shadow: 0 0 10px rgba(57, 255, 20, 0.4);
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    font-size: 0.8rem;
    padding: 0.35rem 0.9rem;
    border-radius: 4px;
    border: 1px solid;
    transition: all 0.3s ease;
    cursor: default;
  }

  /* Blue */
  .skill-tag--blue {
    background: rgba(0, 229, 255, 0.06);
    border-color: rgba(0, 229, 255, 0.15);
    color: #00e5ff;
  }

  .skill-tag--blue:hover {
    background: rgba(0, 229, 255, 0.14);
    border-color: rgba(0, 229, 255, 0.4);
    box-shadow: 0 0 10px rgba(0, 229, 255, 0.25);
    text-shadow: 0 0 6px rgba(0, 229, 255, 0.6);
    transform: scale(1.05);
  }

  /* Pink */
  .skill-tag--pink {
    background: rgba(255, 45, 149, 0.06);
    border-color: rgba(255, 45, 149, 0.15);
    color: #ff2d95;
  }

  .skill-tag--pink:hover {
    background: rgba(255, 45, 149, 0.14);
    border-color: rgba(255, 45, 149, 0.4);
    box-shadow: 0 0 10px rgba(255, 45, 149, 0.25);
    text-shadow: 0 0 6px rgba(255, 45, 149, 0.6);
    transform: scale(1.05);
  }

  /* Green */
  .skill-tag--green {
    background: rgba(57, 255, 20, 0.06);
    border-color: rgba(57, 255, 20, 0.15);
    color: #39ff14;
  }

  .skill-tag--green:hover {
    background: rgba(57, 255, 20, 0.14);
    border-color: rgba(57, 255, 20, 0.4);
    box-shadow: 0 0 10px rgba(57, 255, 20, 0.25);
    text-shadow: 0 0 6px rgba(57, 255, 20, 0.6);
    transform: scale(1.05);
  }

  /* Purple */
  .skill-tag--purple {
    background: rgba(191, 95, 255, 0.06);
    border-color: rgba(191, 95, 255, 0.15);
    color: #bf5fff;
  }

  .skill-tag--purple:hover {
    background: rgba(191, 95, 255, 0.14);
    border-color: rgba(191, 95, 255, 0.4);
    box-shadow: 0 0 10px rgba(191, 95, 255, 0.25);
    text-shadow: 0 0 6px rgba(191, 95, 255, 0.6);
    transform: scale(1.05);
  }

  @media (max-width: 400px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }

    .skill-category {
      padding: 1.4rem;
    }
  }
</style>
