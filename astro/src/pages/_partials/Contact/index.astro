---
import { contact } from "../../../data/contact";
import "./styles.css";
---

<section id="contact">
    <h2 class="section-title title-blue reveal">
        Let's Connect<span class="line"></span>
    </h2>

    <p class="contact-subtitle reveal">
        Open to new opportunities, collaborations, and interesting
        conversations. Don't hesitate to reach out!
    </p>

    <div class="contact-grid">
        {
            contact.map((item, index) => (
                <a
                    href={item.value}
                    class={`contact-card reveal stagger-${(index % 3) + 1} ${item.iconColor}-card`}
                    target={item.isExternal ? "_blank" : undefined}
                    rel={item.isExternal ? "noopener noreferrer" : undefined}
                >
                    <div class={`contact-icon ${item.iconColor}`}>
                        {item.icon}
                    </div>
                    <div class="contact-info">
                        <div class="contact-label">{item.label}</div>
                        <div class="contact-value">{item.displayValue}</div>
                    </div>
                </a>
            ))
        }
    </div>
</section>
